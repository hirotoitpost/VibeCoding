# ========================================
# VibeCoding プロジェクト - 環境変数テンプレート
# ========================================
# 
# このファイルは .env のテンプレートです。
# 初回セットアップ時に、このファイルを .env にコピーして、
# 各値をあなたの環境に合わせて編集してください。
#
# 注意: .env ファイルは .gitignore で除外されているため、
#       機密情報（APIキーなど）を含めても安全です。
#

# ========================================
# 🎬 AviUtl 設定
# ========================================

# AviUtl のインストール ルートパス
# Windows の例: C:\AviUtl
AVIUTL_ROOT=C:\AviUtl

# ========================================
# 🌤️ WeatherAPI 設定（天気情報ツール用）
# ========================================

# OpenWeatherMap API キー（https://openweathermap.org/api から取得）
# OPENWEATHERMAP_API_KEY=your_api_key_here

# ========================================
# 💾 データベース設定
# ========================================

# PostgreSQL 接続文字列
# DATABASE_URL=postgresql://user:password@localhost:5432/vibecoding_db

# ========================================
# 🤖 AI API 設定
# ========================================

# OpenAI API キー（https://platform.openai.com/api-keys から取得）
# OPENAI_API_KEY=sk-xxx

# ========================================
# 🔗 MQTT ブローカー設定（IoT プロジェクト用）
# ========================================

# MQTT ブローカーのホスト（デフォルト: localhost）
# MQTT_BROKER=localhost

# MQTT ブローカーのポート（デフォルト: 1883）
# MQTT_PORT=1883

# MQTT ユーザー名（認証が必要な場合）
# MQTT_USERNAME=user

# MQTT パスワード（認証が必要な場合）
# MQTT_PASSWORD=password

# ========================================
# 🌐 その他の API キー
# ========================================

# API_KEY_NAME=value_here
