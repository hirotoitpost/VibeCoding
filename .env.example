# ========================================
# VibeCoding プロジェクト - 環境変数テンプレート
# ========================================
# 
# このファイルは .env のテンプレートです。
# 初回セットアップ時に、このファイルを .env にコピーして、
# 各値をあなたの環境に合わせて編集してください。
#
# 注意: .env ファイルは .gitignore で除外されているため、
#       機密情報（APIキーなど）を含めても安全です。
#

# ========================================
# 🎬 AviUtl 設定
# ========================================

# AviUtl のインストール ルートパス
# Windows の例: C:\AviUtl
AVIUTL_ROOT=C:\AviUtl

# ========================================# 🖼️ PSDToolKit 設定（動画生成パイプライン用）
# ========================================

# PSDToolKit プラグイン ルートパス
# Windows の例: C:\AviUtl\plugins\PSDToolKit
# PSDTOOLKIT_ROOT=C:\AviUtl\plugins\PSDToolKit

# ========================================# � VOICEVOX 設定（動画生成パイプライン用）
# ========================================

# VOICEVOX のインストール ルートパス
# Windows の例: C:\Program Files\VOICEVOX
# VOICEVOX_ROOT=C:\Program Files\VOICEVOX

# VOICEVOX API サーバーのポート（デフォルト: 50021）
# VOICEVOX_PORT=50021

# ========================================
# 🎤 動画生成 - 話し手設定（2人体制）
# ========================================

# 話し手1: 進行役
# VOICEVOX スピーカーID (例: 8=春日部つむぎ, 3=ずんだもん, 2=四国めたん)
# SPEAKER_1_ID=8
# SPEAKER_1_STYLE_ID=8

# 話し手2: 相槌役
# VOICEVOX スピーカーID (例: 8=春日部つむぎ, 3=ずんだもん, 2=四国めたん)
# SPEAKER_2_ID=3
# SPEAKER_2_STYLE_ID=3

# ========================================
# 🎨 立ち絵設定（PSD ファイル）
# ========================================

# 立ち絵1: 進行役用 PSD ファイル
# Windows の例: C:\PSD_Assets\character_1.psd
# PSD_CHARACTER_1=/path/to/character_1.psd

# 立ち絵2: 相槌役用 PSD ファイル
# Windows の例: C:\PSD_Assets\character_2.psd
# PSD_CHARACTER_2=/path/to/character_2.psd

# ========================================

# OpenWeatherMap API キー（https://openweathermap.org/api から取得）
# OPENWEATHERMAP_API_KEY=your_api_key_here

# ========================================
# 💾 データベース設定
# ========================================

# PostgreSQL 接続文字列
# DATABASE_URL=postgresql://user:password@localhost:5432/vibecoding_db

# ========================================
# 🤖 AI API 設定
# ========================================

# OpenAI API キー（https://platform.openai.com/api-keys から取得）
# OPENAI_API_KEY=sk-xxx

# ========================================
# 🔗 MQTT ブローカー設定（IoT プロジェクト用）
# ========================================

# MQTT ブローカーのホスト（デフォルト: localhost）
# MQTT_BROKER=localhost

# MQTT ブローカーのポート（デフォルト: 1883）
# MQTT_PORT=1883

# MQTT ユーザー名（認証が必要な場合）
# MQTT_USERNAME=user

# MQTT パスワード（認証が必要な場合）
# MQTT_PASSWORD=password

# ========================================
# 🌐 その他の API キー
# ========================================

# API_KEY_NAME=value_here
