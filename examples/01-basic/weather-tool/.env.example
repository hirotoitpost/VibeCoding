# OpenWeatherMap API Configuration
OPENWEATHER_API_KEY=your_api_key_here

# City to fetch weather for
CITY=Tokyo

# Cache settings (in minutes)
CACHE_DURATION_MINUTES=5

# Cache directory
CACHE_DIR=./cache

# Optional: Language (en, ja, etc.)
# LANGUAGE=ja

# Optional: Unit system (metric, imperial, standard)
# UNIT_SYSTEM=metric
