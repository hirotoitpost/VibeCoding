# 環境変数設定テンプレート - IoT センサーシミュレーター
# このファイルを .env にコピーして、各環境に合わせて編集してください

# ============================================================
# MQTT ブローカー設定
# ============================================================
MQTT_BROKER_HOST=mosquitto          # Docker Compose サービス名
MQTT_BROKER_PORT=1883               # 標準 MQTT ポート
MQTT_USERNAME=                      # 認証ユーザー名（オプション）
MQTT_PASSWORD=                      # 認証パスワード（オプション）
MQTT_TOPIC_PREFIX=sensor            # トピックプリフィックス
MQTT_CLIENT_ID=iot_simulator_001   # クライアントID

# ============================================================
# データベース設定
# ============================================================
DATABASE_TYPE=sqlite                # sqlite or postgresql
DATABASE_URL=sqlite:///sensor_data.db    # SQLite パス
# DATABASE_URL=postgresql://user:password@localhost:5432/iot_db  # PostgreSQL
DATABASE_ECHO=false                 # SQLite ログ出力（デバッグ用）

# ============================================================
# センサーシミュレーター設定
# ============================================================
SENSOR_INTERVAL=5                   # データ生成間隔（秒）
SENSOR_COUNT=3                      # シミュレーションセンサー数
SENSOR_ROOMS=room1,room2,room3      # ルーム名（カンマ区切り）

# 温度シミュレーション
TEMP_MIN=10                         # 最小温度（℃）
TEMP_MAX=35                         # 最大温度（℃）
TEMP_VARIANCE=2.0                   # 温度変化幅（℃）

# 湿度シミュレーション
HUMIDITY_MIN=20                     # 最小湿度（%）
HUMIDITY_MAX=95                     # 最大湿度（%）
HUMIDITY_VARIANCE=5.0               # 湿度変化幅（%）

# ============================================================
# アラーム設定
# ============================================================
ALARM_TEMP_HIGH=30                  # 高温アラーム閾値（℃）
ALARM_TEMP_LOW=5                    # 低温アラーム閾値（℃）
ALARM_HUMIDITY_HIGH=80              # 高湿度アラーム閾値（%）
ALARM_HUMIDITY_LOW=40               # 低湿度アラーム閾値（%）
ALARM_NOTIFY_INTERVAL=60            # アラーム通知間隔（秒）

# ============================================================
# Web アプリケーション設定
# ============================================================
FLASK_ENV=development               # development or production
FLASK_DEBUG=true                    # デバッグモード
FLASK_HOST=0.0.0.0                 # バインドアドレス
FLASK_PORT=5000                     # ポート番号
SECRET_KEY=your-secret-key-here     # SESSION/CSRF トークン用

# ============================================================
# ログ設定
# ============================================================
LOG_LEVEL=INFO                      # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/iot_simulator.log     # ログファイルパス
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ============================================================
# 本番環境  設定
# ============================================================
# PRODUCTION=true
# MQTT_BROKER_HOST=mqtt.production.example.com
# DATABASE_URL=postgresql://prod_user:secure_pass@db.example.com:5432/iot_prod
# SECRET_KEY=your-production-secret-key-here
# FLASK_ENV=production
# FLASK_DEBUG=false
